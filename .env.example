# OpenAI-compatible API base URL (e.g. local LM Studio, Ollama, OpenAI, etc.)
VITE_OPENAI_BASE_URL=http://localhost:1234/v1

# API key (use "your-api-key-here" for your actual key)
VITE_OPENAI_API_KEY=your-api-key-here

# Agent model routing (optional)
# Default: developer -> claude, tester -> codex
# AGENT_MODEL_DEVELOPER=claude
# AGENT_MODEL_TESTER=codex
